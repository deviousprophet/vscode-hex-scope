{
  "name": "vscode-hex-scope",
  "displayName": "Hex Scope",
  "publisher": "deviousprophet",
  "description": "VS Code extension for viewing and analyzing firmware files (HEX, SREC) with hex grid, search, patching.",
  "version": "2.5.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/deviousprophet/vscode-hex-scope"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "icon": "images/icon.png",
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "intel-hex",
        "aliases": [
          "Intel HEX",
          "ihex"
        ],
        "extensions": [
          ".hex"
        ]
      },
      {
        "id": "srec",
        "aliases": [
          "Motorola SREC",
          "srec"
        ],
        "extensions": [
          ".srec",
          ".mot",
          ".s19",
          ".s28",
          ".s37"
        ]
      }
    ],
    "grammars": [
      {
        "language": "intel-hex",
        "scopeName": "source.intel-hex",
        "path": "./syntaxes/intel-hex.tmLanguage.json"
      },
      {
        "language": "srec",
        "scopeName": "source.srec",
        "path": "./syntaxes/srec.tmLanguage.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "hexScope.hexEditor",
        "displayName": "HexScope Viewer",
        "selector": [
          {
            "filenamePattern": "*.hex"
          },
          {
            "filenamePattern": "*.srec"
          },
          {
            "filenamePattern": "*.mot"
          },
          {
            "filenamePattern": "*.s19"
          },
          {
            "filenamePattern": "*.s28"
          },
          {
            "filenamePattern": "*.s37"
          }
        ],
        "priority": "option"
      }
    ],
    "submenus": [
      {
        "id": "hexScope.actions",
        "label": "HexScope"
      }
    ],
    "commands": [
      {
        "command": "hexScope.addSegmentLabel",
        "title": "Add Segment Label",
        "category": "HexScope"
      },
      {
        "command": "hexScope.copyAsHexString",
        "title": "Copy Selection as Hex String",
        "category": "HexScope"
      },
      {
        "command": "hexScope.copyAsCArray",
        "title": "Copy Selection as C Array",
        "category": "HexScope"
      },
      {
        "command": "hexScope.copyAsAscii",
        "title": "Copy Selection as ASCII",
        "category": "HexScope"
      },
      {
        "command": "hexScope.copyRawRecord",
        "title": "Copy Raw HEX Record",
        "category": "HexScope"
      },
      {
        "command": "hexScope.quickRepair",
        "title": "Quick Repair Checksums",
        "category": "HexScope"
      },
      {
        "command": "hexScope.openInHexScope",
        "title": "Open with HexScope Viewer",
        "icon": "$(symbol-misc)",
        "category": "HexScope"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "hexScope.actions",
          "when": "(resourceExtname == .hex || resourceExtname == .srec || resourceExtname == .mot || resourceExtname == .s19 || resourceExtname == .s28 || resourceExtname == .s37)",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "submenu": "hexScope.actions",
          "when": "(resourceExtname == .hex || resourceExtname == .srec || resourceExtname == .mot || resourceExtname == .s19 || resourceExtname == .s28 || resourceExtname == .s37) && activeEditorIsNotPreview",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "submenu": "hexScope.actions",
          "when": "(resourceExtname == .hex || resourceExtname == .srec || resourceExtname == .mot || resourceExtname == .s19 || resourceExtname == .s28 || resourceExtname == .s37)",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "submenu": "hexScope.actions",
          "when": "(resourceExtname == .hex || resourceExtname == .srec || resourceExtname == .mot || resourceExtname == .s19 || resourceExtname == .s28 || resourceExtname == .s37) && activeCustomEditorId != 'hexScope.hexEditor'",
          "group": "navigation"
        }
      ],
      "hexScope.actions": [
        {
          "command": "hexScope.openInHexScope",
          "when": "resourceExtname == .hex || resourceExtname == .srec || resourceExtname == .mot || resourceExtname == .s19 || resourceExtname == .s28 || resourceExtname == .s37",
          "group": "navigation"
        },
        {
          "command": "hexScope.quickRepair",
          "when": "resourceExtname == .hex || resourceExtname == .srec || resourceExtname == .mot || resourceExtname == .s19 || resourceExtname == .s28 || resourceExtname == .s37",
          "group": "navigation"
        }
      ]
    },
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "punctuation.ihex.start-code",
            "settings": {
              "foreground": "#6a6a6a"
            }
          },
          {
            "scope": "meta.ihex.byte-count",
            "settings": {
              "foreground": "#858585"
            }
          },
          {
            "scope": "meta.ihex.address",
            "settings": {
              "foreground": "#c6c6c6",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "meta.ihex.record-type.data",
            "settings": {
              "foreground": "#4ec9a0",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "meta.ihex.record-type.eof",
            "settings": {
              "foreground": "#ce9178",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "meta.ihex.record-type.extended-address",
            "settings": {
              "foreground": "#9cdcfe",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "meta.ihex.record-type.start-address",
            "settings": {
              "foreground": "#9cdcfe",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "meta.ihex.data",
            "settings": {
              "foreground": "#ce9178"
            }
          },
          {
            "scope": "meta.ihex.extended-address-value",
            "settings": {
              "foreground": "#9cdcfe"
            }
          },
          {
            "scope": "meta.ihex.checksum",
            "settings": {
              "foreground": "#858585"
            }
          },
          {
            "scope": "invalid.illegal.ihex",
            "settings": {
              "foreground": "#f48771"
            }
          },
          {
            "scope": "punctuation.srec.start-code",
            "settings": {
              "foreground": "#6a6a6a"
            }
          },
          {
            "scope": "meta.srec.byte-count",
            "settings": {
              "foreground": "#858585"
            }
          },
          {
            "scope": "meta.srec.address",
            "settings": {
              "foreground": "#c6c6c6",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "meta.srec.record-type.data",
            "settings": {
              "foreground": "#4ec9a0",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "meta.srec.record-type.eof",
            "settings": {
              "foreground": "#ce9178",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "meta.srec.record-type.extended-address",
            "settings": {
              "foreground": "#9cdcfe",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "meta.srec.data",
            "settings": {
              "foreground": "#ce9178"
            }
          },
          {
            "scope": "meta.srec.checksum",
            "settings": {
              "foreground": "#858585"
            }
          },
          {
            "scope": "invalid.illegal.srec",
            "settings": {
              "foreground": "#f48771"
            }
          }
        ]
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/jsdom": "^28.0.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
