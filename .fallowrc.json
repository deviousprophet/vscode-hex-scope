{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/extension.ts",
    "src/webview/hexViewer.ts",
    "src/test/**/*.test.ts",
    ".vscode-test.mjs",
    "esbuild.js"
  ],
  "dynamicallyLoaded": [
    "src/webview/styles/*.css"
  ],
  "usedClassMembers": [
    {
      "implements": "vscode.CustomReadonlyEditorProvider",
      "members": [
        "openCustomDocument",
        "resolveCustomEditor"
      ]
    }
  ]
}
